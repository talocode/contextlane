{
  "name": "@talocode/contextlane",
  "version": "0.2.0",
  "description": "Open-source context ingestion pipeline for persistent AI agents — turn files, folders, URLs, repos, and notes into structured memory with citations",
  "type": "module",
  "bin": {
    "contextlane": "dist/cli.cjs"
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node scripts/test.mjs",
    "prepublishOnly": "npm test",
    "start:api": "node dist/server.cjs",
    "start:mcp": "node dist/mcp.cjs",
    "demo": "node dist/cli.cjs demo"
  },
  "keywords": [
    "context", "ai-agents", "memory", "ingestion", "mcp",
    "sdk", "cli", "talocode", "persistent-intelligence", "open-source"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "@modelcontextprotocol/sdk": "^1.13.0"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=18"
  }
}
