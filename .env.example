# ContextLane Configuration
# Copy to .env or set in your shell profile

# Storage location for all ingestion artifacts
CONTEXTLANE_HOME=~/.contextlane

# Storage driver (json only for v0.1.0)
CONTEXTLANE_STORAGE_DRIVER=json

# Cloud mode (requires TALOCODE_API_KEY)
# CONTEXTLANE_CLOUD_MODE=true

# Talocode API key (required for cloud mode)
# TALOCODE_API_KEY=your_key_here

# MemoryLane URL (optional, for direct HTTP sync)
# CONTEXTLANE_MEMORYLANE_URL=http://localhost:3040
